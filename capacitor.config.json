{
  "appId": "com.speaksprint.app",
  "appName": "SpeakSprint",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#0a0a0f"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a0f",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
